<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvPermissionStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Estado del permiso: Desconocido"
        android:textSize="18sp"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnRequestPermission"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Solicitar permiso de notificaciones" />

    <Button
        android:id="@+id/btnShowGeneral"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mostrar notificación general de prueba" />

    <Button
        android:id="@+id/btnShowUrgent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mostrar notificación urgente de prueba" />

    <Button
        android:id="@+id/btnCheckStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ver estado del permiso" />

</LinearLayout>